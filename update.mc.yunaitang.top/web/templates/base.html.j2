<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#1e1e2e">
    <title>{% block title %}{{ _('title') }}{% endblock %}</title>
    <link rel="stylesheet" href="/admin/static/fonts.css">
    <link rel="stylesheet" href="/admin/static/style.css">
    {% block head %}{% endblock %}
</head>
<body>
    {% if request.session.get("admin_authenticated") %}
    <nav class="top-nav" id="top-nav">
        <div class="nav-inner">
            <a href="/admin/releases?lang={{ lang }}" class="nav-brand">{{ _('title') }}</a>
            <div class="nav-actions">
                <a href="{{ toggle_url }}" class="lang-toggle" title="{{ 'Switch to English' if toggle_lang == 'en' else '切换到中文' }}">
                    {{ 'EN' if toggle_lang == 'en' else '中文' }}
                </a>
                <span class="nav-user">{{ _('nav_admin') }}</span>
                <a href="/admin/logout?lang={{ lang }}" class="nav-link">{{ _('nav_logout') }}</a>
            </div>
        </div>
    </nav>
    {% endif %}

    <main class="main-content">
        {% block content %}{% endblock %}
    </main>

    <footer class="footer">
        <p>{{ _('footer') }}</p>
    </footer>

    <script>
    (function() {
        var nav = document.getElementById('top-nav');
        if (!nav) return;
        function onScroll() {
            if (window.scrollY > 10) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        }
        window.addEventListener('scroll', onScroll, {passive: true});
        onScroll();
    })();
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>
