{
  "name": "水墨",
  "description": "国风水墨主题，宣纸为底、浓墨为骨、朱红为魂",
  "version": "1.0.0",
  "settings": [
    {
      "key": "color_scheme",
      "label": "配色方案",
      "type": "select",
      "options": [
        { "label": "宣纸暖调（浅色）", "value": "warm" },
        { "label": "夜墨冷调（深色）", "value": "dark" }
      ],
      "default": "warm"
    },
    {
      "key": "hero_style",
      "label": "卷首背景",
      "type": "select",
      "options": [
        { "label": "水墨山水", "value": "ink" },
        { "label": "素纸留白", "value": "plain" },
        { "label": "自定义图片", "value": "image" }
      ],
      "default": "ink"
    },
    {
      "key": "hero_image",
      "label": "卷首背景图片",
      "type": "image",
      "placeholder": "选择或上传背景图片（建议 1920x1080 以上）",
      "default": "",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "hero_overlay",
      "label": "背景遮罩",
      "type": "select",
      "options": [
        { "label": "淡墨遮罩", "value": "dark" },
        { "label": "宣纸遮罩（暗色模式下不可用）", "value": "light", "disable_when": { "key": "color_scheme", "value": "dark" } },
        { "label": "无遮罩", "value": "none" }
      ],
      "default": "light",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "accent_color",
      "label": "点缀色",
      "type": "select",
      "options": [
        { "label": "朱红", "value": "vermillion" },
        { "label": "赤金", "value": "gold" },
        { "label": "青玉", "value": "jade" }
      ],
      "default": "vermillion"
    },
    {
      "key": "title_animation",
      "label": "卷首题字动画",
      "type": "switch",
      "default": true
    },
    {
      "key": "favicon_url",
      "label": "Favicon",
      "type": "input",
      "placeholder": "浏览器标签图标地址",
      "default": ""
    },
    {
      "key": "icp_number",
      "label": "备案号",
      "type": "input",
      "placeholder": "如 京ICP备xxxxxxxx号",
      "default": ""
    },
    {
      "key": "server_address_display",
      "label": "服务器地址",
      "type": "input",
      "placeholder": "如 play.example.com",
      "default": ""
    },
    {
      "key": "qq_group",
      "label": "QQ 群",
      "type": "input",
      "placeholder": "QQ 群号",
      "default": ""
    },
    {
      "key": "discord_link",
      "label": "Discord",
      "type": "input",
      "placeholder": "Discord 邀请链接",
      "default": ""
    },
    {
      "key": "custom_css",
      "label": "自定义 CSS",
      "type": "textarea",
      "placeholder": "在此输入自定义样式，会注入到页面 <head> 中",
      "default": ""
    }
  ]
}
