{
  "name": "以太_Mocha",
  "description": "以太主题的 Catppuccin Mocha 深色变体 — 毛玻璃质感 × 柔和夜间配色",
  "version": "1.0.0",
  "settings": [
    {
      "key": "hero_style",
      "label": "首屏背景",
      "type": "select",
      "options": [
        { "label": "渐变光晕", "value": "mesh" },
        { "label": "纯色背景", "value": "clean" },
        { "label": "自定义图片", "value": "image" }
      ],
      "default": "mesh"
    },
    {
      "key": "hero_image",
      "label": "首屏背景图片",
      "type": "image",
      "placeholder": "选择或上传背景图片（建议 1920x1080 以上）",
      "default": "",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "hero_overlay",
      "label": "背景遮罩",
      "type": "select",
      "options": [
        { "label": "深色遮罩", "value": "dark" },
        { "label": "浅色磨砂", "value": "light" },
        { "label": "无遮罩", "value": "none" }
      ],
      "default": "dark",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "accent_color",
      "label": "强调色",
      "type": "select",
      "options": [
        { "label": "猫眼石蓝", "value": "sapphire" },
        { "label": "淡紫", "value": "mauve" },
        { "label": "天空蓝", "value": "sky" },
        { "label": "薄荷绿", "value": "teal" },
        { "label": "蜜桃橙", "value": "peach" },
        { "label": "玫瑰红", "value": "rosewater" }
      ],
      "default": "sapphire"
    },
    {
      "key": "glass_intensity",
      "label": "毛玻璃强度",
      "type": "select",
      "options": [
        { "label": "轻柔", "value": "light" },
        { "label": "标准", "value": "medium" },
        { "label": "浓厚", "value": "heavy" }
      ],
      "default": "medium"
    },
    {
      "key": "card_radius",
      "label": "卡片圆角",
      "type": "select",
      "options": [
        { "label": "大圆角 (20px)", "value": "20" },
        { "label": "标准 (16px)", "value": "16" },
        { "label": "小圆角 (10px)", "value": "10" }
      ],
      "default": "16"
    },
    {
      "key": "mesh_animation",
      "label": "背景光晕动画",
      "type": "switch",
      "default": true
    },
    {
      "key": "logo_url",
      "label": "导航栏 Logo",
      "type": "image",
      "placeholder": "选择或上传 Logo 图片（建议高度 32px 以上，透明背景）",
      "default": ""
    },
    {
      "key": "favicon_url",
      "label": "Favicon",
      "type": "input",
      "placeholder": "浏览器标签图标地址",
      "default": ""
    },
    {
      "key": "custom_css",
      "label": "自定义 CSS",
      "type": "textarea",
      "placeholder": "在此输入自定义样式，会注入到页面 <head> 中",
      "default": ""
    }
  ]
}
