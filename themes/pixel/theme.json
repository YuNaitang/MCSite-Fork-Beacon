{
  "name": "像素",
  "description": "复古操作系统桌面，Win95 风窗口管理，像素字体，CRT 扫描线",
  "version": "2.0.0",
  "settings": [
    {
      "key": "accent_color",
      "label": "主题色",
      "type": "select",
      "options": [
        { "label": "终端绿", "value": "green" },
        { "label": "琥珀金", "value": "amber" },
        { "label": "赛博青", "value": "cyan" },
        { "label": "警报红", "value": "red" },
        { "label": "暗紫", "value": "purple" }
      ],
      "default": "green"
    },
    {
      "key": "hero_style",
      "label": "桌面壁纸",
      "type": "select",
      "options": [
        { "label": "像素网格", "value": "grid" },
        { "label": "纯色", "value": "solid" },
        { "label": "自定义图片", "value": "image" }
      ],
      "default": "grid"
    },
    {
      "key": "hero_image",
      "label": "壁纸图片",
      "type": "image",
      "placeholder": "选择或上传壁纸图片",
      "default": "",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "scanlines",
      "label": "CRT 扫描线",
      "type": "switch",
      "default": true
    },
    {
      "key": "title_animation",
      "label": "窗口动画",
      "type": "switch",
      "default": true
    },
    {
      "key": "favicon_url",
      "label": "Favicon",
      "type": "input",
      "placeholder": "浏览器标签图标地址",
      "default": ""
    },
    {
      "key": "icp_number",
      "label": "备案号",
      "type": "input",
      "placeholder": "如 京ICP备xxxxxxxx号",
      "default": ""
    },
    {
      "key": "server_address_display",
      "label": "服务器地址",
      "type": "input",
      "placeholder": "如 play.example.com",
      "default": ""
    },
    {
      "key": "qq_group",
      "label": "QQ 群",
      "type": "input",
      "placeholder": "QQ 群号",
      "default": ""
    },
    {
      "key": "discord_link",
      "label": "Discord",
      "type": "input",
      "placeholder": "Discord 邀请链接",
      "default": ""
    },
    {
      "key": "custom_css",
      "label": "自定义 CSS",
      "type": "textarea",
      "placeholder": "在此输入自定义样式，会注入到页面 <head> 中",
      "default": ""
    }
  ]
}
