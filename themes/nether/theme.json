{
  "name": "地狱熔炉",
  "description": "黑曜石底板上的岩浆裂缝与灵魂之火仪表盘",
  "version": "1.0.0",
  "settings": [
    {
      "key": "hero_style",
      "label": "卷首背景",
      "type": "select",
      "options": [
        { "label": "熔岩裂缝", "value": "lava" },
        { "label": "深渊黑", "value": "abyss" },
        { "label": "自定义图片", "value": "image" }
      ],
      "default": "lava"
    },
    {
      "key": "hero_image",
      "label": "卷首背景图片",
      "type": "image",
      "placeholder": "选择或上传背景图片（建议 1920x1080 以上）",
      "default": "",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "hero_overlay",
      "label": "背景遮罩",
      "type": "select",
      "options": [
        { "label": "深色遮罩", "value": "dark" },
        { "label": "浅色遮罩", "value": "light" },
        { "label": "无遮罩", "value": "none" }
      ],
      "default": "dark",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "lava_intensity",
      "label": "岩浆动画强度",
      "type": "select",
      "options": [
        { "label": "低", "value": "low" },
        { "label": "中", "value": "medium" },
        { "label": "高", "value": "high" }
      ],
      "default": "medium"
    },
    {
      "key": "accent_color",
      "label": "强调色",
      "type": "select",
      "options": [
        { "label": "熔岩橙", "value": "lava" },
        { "label": "灵魂火焰青", "value": "soul" },
        { "label": "红石红", "value": "redstone" }
      ],
      "default": "lava"
    },
    {
      "key": "card_radius",
      "label": "卡片圆角",
      "type": "select",
      "options": [
        { "label": "圆润 (14px)", "value": "14" },
        { "label": "适中 (8px)", "value": "8" },
        { "label": "直角 (2px)", "value": "2" }
      ],
      "default": "14"
    },
    {
      "key": "title_animation",
      "label": "标题入场动画",
      "type": "switch",
      "default": true
    },
    {
      "key": "favicon_url",
      "label": "Favicon",
      "type": "input",
      "placeholder": "浏览器标签图标地址",
      "default": ""
    },
    {
      "key": "icp_number",
      "label": "备案号",
      "type": "input",
      "placeholder": "如 京ICP备xxxxxxxx号",
      "default": ""
    },
    {
      "key": "server_address_display",
      "label": "服务器地址展示",
      "type": "input",
      "placeholder": "如 play.example.com",
      "default": ""
    },
    {
      "key": "qq_group",
      "label": "QQ 群",
      "type": "input",
      "placeholder": "QQ 群号",
      "default": ""
    },
    {
      "key": "discord_link",
      "label": "Discord",
      "type": "input",
      "placeholder": "Discord 邀请链接",
      "default": ""
    },
    {
      "key": "custom_css",
      "label": "自定义 CSS",
      "type": "textarea",
      "placeholder": "在此输入自定义样式，会注入到页面 <head> 中",
      "default": ""
    }
  ]
}
