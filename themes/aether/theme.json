{
  "name": "以太",
  "description": "柔光渐变上的毛玻璃信息面板 — 呼吸感的现代极简控制台",
  "version": "1.0.0",
  "settings": [
    {
      "key": "hero_style",
      "label": "首屏背景",
      "type": "select",
      "options": [
        { "label": "渐变网格", "value": "mesh" },
        { "label": "纯净白", "value": "clean" },
        { "label": "自定义图片", "value": "image" }
      ],
      "default": "mesh"
    },
    {
      "key": "hero_image",
      "label": "首屏背景图片",
      "type": "image",
      "placeholder": "选择或上传背景图片（建议 1920x1080 以上）",
      "default": "",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "hero_overlay",
      "label": "背景遮罩",
      "type": "select",
      "options": [
        { "label": "浅色磨砂", "value": "light" },
        { "label": "深色遮罩", "value": "dark" },
        { "label": "无遮罩", "value": "none" }
      ],
      "default": "light",
      "show_when": { "key": "hero_style", "value": "image" }
    },
    {
      "key": "accent_color",
      "label": "强调色",
      "type": "select",
      "options": [
        { "label": "紫罗兰", "value": "violet" },
        { "label": "天际蓝", "value": "sky" },
        { "label": "翡翠绿", "value": "emerald" },
        { "label": "琥珀橙", "value": "amber" }
      ],
      "default": "violet"
    },
    {
      "key": "glass_intensity",
      "label": "毛玻璃强度",
      "type": "select",
      "options": [
        { "label": "轻柔", "value": "light" },
        { "label": "标准", "value": "medium" },
        { "label": "浓厚", "value": "heavy" }
      ],
      "default": "medium"
    },
    {
      "key": "card_radius",
      "label": "卡片圆角",
      "type": "select",
      "options": [
        { "label": "大圆角 (20px)", "value": "20" },
        { "label": "标准 (16px)", "value": "16" },
        { "label": "小圆角 (10px)", "value": "10" }
      ],
      "default": "16"
    },
    {
      "key": "mesh_animation",
      "label": "背景渐变动画",
      "type": "switch",
      "default": true
    },
    {
      "key": "logo_url",
      "label": "导航栏 Logo",
      "type": "image",
      "placeholder": "选择或上传 Logo 图片（建议高度 32px 以上，透明背景）",
      "default": ""
    },
    {
      "key": "favicon_url",
      "label": "Favicon",
      "type": "input",
      "placeholder": "浏览器标签图标地址",
      "default": ""
    },
    {
      "key": "custom_css",
      "label": "自定义 CSS",
      "type": "textarea",
      "placeholder": "在此输入自定义样式，会注入到页面 <head> 中",
      "default": ""
    }
  ]
}
